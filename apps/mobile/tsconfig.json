{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "target": "es2017",
    "lib": [
      "es2017"
    ],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "types": [
      "react",
      "react-native"
    ]
  },
  "extends": "expo/tsconfig.base"
}
